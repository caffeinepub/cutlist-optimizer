export interface StockSheet {
  id: string;
  label: string;
  width: number;
  height: number;
  quantity: number;
  laminateFront?: string;
  laminateBack?: string;
}

export interface CutPiece {
  id: string;
  label: string;
  width: number;
  height: number;
  quantity: number;
  stockSheetId?: string; // optional: restrict to a specific stock sheet
}

export interface PlacedPiece {
  label: string;
  x: number;
  y: number;
  w: number;
  h: number;
  rotated: boolean;
  pieceId: string;
  colorIndex: number;
}

export interface FreeRect {
  x: number;
  y: number;
  w: number;
  h: number;
}

export interface OptimizedSheet {
  stockSheetId: string;
  sheetIndex: number;
  sheetLabel: string;
  sheetWidth: number;
  sheetHeight: number;
  laminateFront: string;
  laminateBack: string;
  placedPieces: PlacedPiece[];
  freeRects: FreeRect[];
  usedArea: number;
  totalArea: number;
  utilization: number;
}

export interface OptimizationResult {
  sheets: OptimizedSheet[];
  totalSheets: number;
  totalArea: number;
  usedArea: number;
  utilization: number;
  unplacedPieces: Array<{ label: string; qty: number }>;
  autoIncreasedSheets: Array<{ sheetLabel: string; addedQty: number }>;
}

function rectFits(pw: number, ph: number, fw: number, fh: number): boolean {
  return pw <= fw && ph <= fh;
}

function guillotineSplit(
  freeRect: FreeRect,
  pw: number,
  ph: number,
): FreeRect[] {
  const result: FreeRect[] = [];
  const rightW = freeRect.w - pw;
  const topH = freeRect.h - ph;

  const splitHorizontal = rightW > topH;

  if (splitHorizontal) {
    if (rightW > 0 && freeRect.h > 0) {
      result.push({
        x: freeRect.x + pw,
        y: freeRect.y,
        w: rightW,
        h: freeRect.h,
      });
    }
    if (pw > 0 && topH > 0) {
      result.push({ x: freeRect.x, y: freeRect.y + ph, w: pw, h: topH });
    }
  } else {
    if (freeRect.w > 0 && topH > 0) {
      result.push({
        x: freeRect.x,
        y: freeRect.y + ph,
        w: freeRect.w,
        h: topH,
      });
    }
    if (rightW > 0 && ph > 0) {
      result.push({ x: freeRect.x + pw, y: freeRect.y, w: rightW, h: ph });
    }
  }

  return result;
}

function findBestFreeRect(
  freeRects: FreeRect[],
  pw: number,
  ph: number,
  allowRotation: boolean,
): { index: number; rotated: boolean } | null {
  let bestIndex = -1;
  let bestRotated = false;
  let bestScore = Number.POSITIVE_INFINITY;

  for (let i = 0; i < freeRects.length; i++) {
    const fr = freeRects[i];

    if (rectFits(pw, ph, fr.w, fr.h)) {
      const score = Math.min(fr.w - pw, fr.h - ph);
      if (score < bestScore) {
        bestScore = score;
        bestIndex = i;
        bestRotated = false;
      }
    }

    if (allowRotation && pw !== ph && rectFits(ph, pw, fr.w, fr.h)) {
      const score = Math.min(fr.w - ph, fr.h - pw);
      if (score < bestScore) {
        bestScore = score;
        bestIndex = i;
        bestRotated = true;
      }
    }
  }

  if (bestIndex === -1) return null;
  return { index: bestIndex, rotated: bestRotated };
}

export function optimize(
  stocks: StockSheet[],
  pieces: CutPiece[],
  allowRotation = true,
  kerf = 0,
): OptimizationResult {
  // Expand pieces by quantity, sorted by area descending
  const allPieces: Array<{ piece: CutPiece; colorIndex: number }> = [];
  for (let idx = 0; idx < pieces.length; idx++) {
    const p = pieces[idx];
    for (let q = 0; q < p.quantity; q++) {
      allPieces.push({ piece: p, colorIndex: idx % 12 });
    }
  }

  // Sort by area desc (use kerf-adjusted area for sorting)
  allPieces.sort((a, b) => {
    const areaA = (a.piece.width + kerf) * (a.piece.height + kerf);
    const areaB = (b.piece.width + kerf) * (b.piece.height + kerf);
    return areaB - areaA;
  });

  // Expand available stock sheets (track remaining and auto-added counts)
  const availableSheets: Array<{
    sheet: StockSheet;
    remaining: number;
    autoAdded: number;
  }> = [];
  for (const s of stocks) {
    availableSheets.push({ sheet: s, remaining: s.quantity, autoAdded: 0 });
  }

  const optimizedSheets: OptimizedSheet[] = [];
  const unplacedPieces: Array<{ label: string; qty: number }> = [];

  const openSheets: Array<{
    sheetDef: StockSheet;
    freeRects: FreeRect[];
    placedPieces: PlacedPiece[];
    sheetIndex: number;
  }> = [];

  // Check if a piece can physically fit on a sheet (ignoring quantity)
  function pieceCanFitOnSheet(
    pw: number,
    ph: number,
    sheet: StockSheet,
  ): boolean {
    return (
      rectFits(pw, ph, sheet.width, sheet.height) ||
      (allowRotation && rectFits(ph, pw, sheet.width, sheet.height))
    );
  }

  function openNewSheet(
    pw: number,
    ph: number,
    preferredStockId?: string,
  ): (typeof openSheets)[0] | null {
    // Try preferred stock first, then any available
    const candidates = preferredStockId
      ? [
          ...availableSheets.filter(
            (a) => a.sheet.id === preferredStockId && a.remaining > 0,
          ),
          ...availableSheets.filter(
            (a) => a.sheet.id !== preferredStockId && a.remaining > 0,
          ),
        ]
      : availableSheets.filter((a) => a.remaining > 0);

    for (const avail of candidates) {
      if (avail.remaining > 0) {
        avail.remaining--;
        const sh = {
          sheetDef: avail.sheet,
          freeRects: [
            { x: 0, y: 0, w: avail.sheet.width, h: avail.sheet.height },
          ],
          placedPieces: [] as PlacedPiece[],
          sheetIndex: optimizedSheets.length + openSheets.length,
        };
        openSheets.push(sh);
        return sh;
      }
    }

    // No sheets remaining — try to auto-increase a sheet that can fit this piece
    const autoTarget = preferredStockId
      ? availableSheets.find((a) => a.sheet.id === preferredStockId)
      : availableSheets.find((a) => pieceCanFitOnSheet(pw, ph, a.sheet));

    if (autoTarget && pieceCanFitOnSheet(pw, ph, autoTarget.sheet)) {
      autoTarget.autoAdded++;
      autoTarget.remaining = 0; // will be decremented right away below
      autoTarget.remaining++;
      autoTarget.remaining--;
      // Open a new sheet of this type
      const sh = {
        sheetDef: autoTarget.sheet,
        freeRects: [
          { x: 0, y: 0, w: autoTarget.sheet.width, h: autoTarget.sheet.height },
        ],
        placedPieces: [] as PlacedPiece[],
        sheetIndex: optimizedSheets.length + openSheets.length,
      };
      openSheets.push(sh);
      return sh;
    }

    return null;
  }

  for (const { piece, colorIndex } of allPieces) {
    // Kerf-adjusted dimensions for fitting
    const pw = piece.width + kerf;
    const ph = piece.height + kerf;
    let placed = false;

    // Determine which open sheets this piece can use
    const eligibleSheets = piece.stockSheetId
      ? openSheets.filter((sh) => sh.sheetDef.id === piece.stockSheetId)
      : openSheets;

    // Try existing open sheets
    for (const sh of eligibleSheets) {
      const fit = findBestFreeRect(sh.freeRects, pw, ph, allowRotation);
      if (fit) {
        const fr = sh.freeRects[fit.index];
        const placedW = fit.rotated ? ph : pw;
        const placedH = fit.rotated ? pw : ph;

        sh.placedPieces.push({
          label: piece.label,
          x: fr.x,
          y: fr.y,
          // Store actual piece size (not kerf-adjusted) for display
          w: fit.rotated ? piece.height : piece.width,
          h: fit.rotated ? piece.width : piece.height,
          rotated: fit.rotated,
          pieceId: piece.id,
          colorIndex,
        });

        const newRects = guillotineSplit(fr, placedW, placedH);
        sh.freeRects.splice(fit.index, 1, ...newRects);
        placed = true;
        break;
      }
    }

    if (!placed) {
      const newSheet = openNewSheet(pw, ph, piece.stockSheetId);
      if (newSheet) {
        // When restricted to a specific stock sheet, only open that type
        if (piece.stockSheetId && newSheet.sheetDef.id !== piece.stockSheetId) {
          // Couldn't open the right sheet type
        } else {
          const fit = findBestFreeRect(
            newSheet.freeRects,
            pw,
            ph,
            allowRotation,
          );
          if (fit) {
            const fr = newSheet.freeRects[fit.index];
            const placedW = fit.rotated ? ph : pw;
            const placedH = fit.rotated ? pw : ph;

            newSheet.placedPieces.push({
              label: piece.label,
              x: fr.x,
              y: fr.y,
              w: fit.rotated ? piece.height : piece.width,
              h: fit.rotated ? piece.width : piece.height,
              rotated: fit.rotated,
              pieceId: piece.id,
              colorIndex,
            });

            const newRects = guillotineSplit(fr, placedW, placedH);
            newSheet.freeRects.splice(fit.index, 1, ...newRects);
            placed = true;
          }
        }
      }

      if (!placed) {
        const existing = unplacedPieces.find((u) => u.label === piece.label);
        if (existing) existing.qty++;
        else unplacedPieces.push({ label: piece.label, qty: 1 });
      }
    }
  }

  // Collect auto-increased sheets info
  const autoIncreasedSheets: Array<{ sheetLabel: string; addedQty: number }> =
    [];
  for (const avail of availableSheets) {
    if (avail.autoAdded > 0) {
      autoIncreasedSheets.push({
        sheetLabel: avail.sheet.label,
        addedQty: avail.autoAdded,
      });
    }
  }

  // Finalize all open sheets
  let totalArea = 0;
  let usedArea = 0;

  for (const sh of openSheets) {
    const sheetTotalArea = sh.sheetDef.width * sh.sheetDef.height;
    const sheetUsedArea = sh.placedPieces.reduce(
      (sum, p) => sum + p.w * p.h,
      0,
    );
    totalArea += sheetTotalArea;
    usedArea += sheetUsedArea;

    optimizedSheets.push({
      sheetIndex: sh.sheetIndex,
      stockSheetId: sh.sheetDef.id,
      sheetLabel: sh.sheetDef.label,
      sheetWidth: sh.sheetDef.width,
      sheetHeight: sh.sheetDef.height,
      laminateFront: sh.sheetDef.laminateFront ?? "",
      laminateBack: sh.sheetDef.laminateBack ?? "",
      placedPieces: sh.placedPieces,
      freeRects: sh.freeRects,
      usedArea: sheetUsedArea,
      totalArea: sheetTotalArea,
      utilization:
        sheetTotalArea > 0 ? (sheetUsedArea / sheetTotalArea) * 100 : 0,
    });
  }

  return {
    sheets: optimizedSheets,
    totalSheets: optimizedSheets.length,
    totalArea,
    usedArea,
    utilization: totalArea > 0 ? (usedArea / totalArea) * 100 : 0,
    unplacedPieces,
    autoIncreasedSheets,
  };
}
